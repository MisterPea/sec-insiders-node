    {
      "version": "0.2.0",
      "configurations": [
        {
          "name": "Debug with tsx",
          "type": "node",
          "request": "launch",
          "runtimeExecutable": "npm",
          "runtimeArgs": [
            "run",
            "dev"
          ],
          "skipFiles": [
            "<node_internals>/**"
          ],
          "console": "integratedTerminal",
          "restart": true // Optional: Restarts the debugger on file changes
        }
      ]
    }